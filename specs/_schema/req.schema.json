{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/avi-k-mishra/d365-sdd/specs/_schema/req.schema.json",
  "title": "Atomic requirement (REQ) front-matter",
  "description": "Deterministic contract for the YAML front-matter of every specs/requirements/REQ-####.md file. Intake (Phase 1) must satisfy the required provenance core; refinement (Phase 2) adds the enrichment fields. Body-section rules (Acceptance scenarios / NFR / Notes) are checked separately by scripts/validate_reqs.py.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "source_file", "location", "author", "sha256", "confidence"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^REQ-[0-9]{4}$",
      "description": "Zero-padded, sequential id (conventions.yml req_id_format)."
    },
    "source_file": {
      "type": "string",
      "pattern": "^intake/.+",
      "description": "Path to the evidence document under intake/ (validator also checks it exists on disk)."
    },
    "location": {
      "type": "string",
      "minLength": 1,
      "description": "Where in the source the requirement was found (page / slide / cell / section)."
    },
    "author": {
      "type": "string",
      "minLength": 1
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "SHA-256 of the source file, lowercase hex."
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"],
      "description": "Extraction confidence. 'low' is well-formed but the validator emits a warning for the human reviewer."
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "Added in Phase 2 refinement."
    },
    "type": {
      "type": "string",
      "enum": ["functional", "non-functional", "integration", "data", "security", "agentic"],
      "description": "conventions.yml requirement_types. Added in Phase 2."
    },
    "module": {
      "type": "string",
      "enum": ["Sales", "Service", "ContactCenter", "PowerPlatform", "Azure", "CopilotStudio"],
      "description": "conventions.yml modules. Added in Phase 2."
    },
    "priority": {
      "type": "string",
      "enum": ["Must", "Should", "Could", "Wont"],
      "description": "MoSCoW (conventions.yml priorities). Added in Phase 2."
    },
    "status": {
      "type": "string",
      "enum": ["draft", "reviewed", "approved", "building", "done"],
      "description": "conventions.yml status_flow, forward-only. Intake writes 'draft'."
    },
    "feature": {
      "type": "string",
      "pattern": "^FEAT-[0-9]{2}$",
      "description": "Set in Phase 2 grouping."
    },
    "epic": {
      "type": "string",
      "pattern": "^EPIC-[0-9]{2}$",
      "description": "Set in Phase 2 grouping."
    },
    "depends_on": {
      "type": "array",
      "items": { "type": "string", "pattern": "^REQ-[0-9]{4}$" },
      "uniqueItems": true,
      "description": "Acyclic dependency ids, completed in Phase 2."
    },
    "grounding": {
      "type": "array",
      "items": { "type": "string", "format": "uri" },
      "description": "Microsoft Learn (or other authoritative) URLs backing the criteria."
    },
    "nfr": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["metric", "target"],
        "properties": {
          "metric": { "type": "string", "enum": ["agent_response", "page_load", "crud_action", "availability", "throughput"] },
          "target": { "type": "string", "minLength": 1 }
        }
      },
      "description": "Structured NFRs (conventions.yml nfr_categories). Never free prose."
    }
  }
}
